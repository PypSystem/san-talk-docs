{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Talk AI",
  "colors": {
    "primary": "#004bad",
    "light": "#1875f0",
    "dark": "#003d8f"
  },
  "appearance": {
    "default": "light"
  },
  "favicon": "/favicon.svg",
  "rounded": "relaxed",
  "font": {
    "headings": {
      "weight": 700
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentação",
        "groups": [
          {
            "group": "Primeiros passos",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "Atendimento",
            "pages": [
              "atendimento/visao-geral",
              "atendimento/conversas",
              "atendimento/central-de-conversas",
              "atendimento/copilot",
              "atendimento/atendente-passivo",
              "atendimento/mensagens-rapidas",
              "atendimento/widget-de-chat"
            ]
          },
          {
            "group": "Identidade",
            "pages": [
              "ia-e-personalidade/comunicacao",
              "ia-e-personalidade/diretrizes",
              "ia-e-personalidade/compliance",
              "ia-e-personalidade/esclarecimentos",
              "operacoes/campos-de-qualificacao",
              "operacoes/roteamento",
              "operacoes/horarios-de-atendimento",
              "ia-e-personalidade/contexto-situacional"
            ]
          },
          {
            "group": "Base de conhecimento",
            "pages": [
              "base-de-conhecimento/visao-geral",
              "base-de-conhecimento/documentos",
              "base-de-conhecimento/perguntas-e-respostas",
              "base-de-conhecimento/sites"
            ]
          },
          {
            "group": "Canais",
            "pages": [
              "canais/whatsapp",
              "canais/waba-onboarding",
              "canais/whatsapp-business",
              "canais/waba-bsp",
              "canais/waba-troubleshooting",
              "canais/templates"
            ]
          },
          {
            "group": "Campanhas e contatos",
            "pages": [
              "campanhas/criar-e-gerenciar",
              "campanhas/metricas",
              "contatos/gerenciar-contatos"
            ]
          },
          {
            "group": "Configurações",
            "pages": [
              "operacoes/sla"
            ]
          },
          {
            "group": "Gestão",
            "pages": [
              "administracao/empresas-e-unidades",
              "administracao/usuarios-e-permissoes",
              "avaliacao/conversas",
              "avaliacao/atendentes"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Visão geral",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Conceitos",
            "pages": [
              "concepts/authentication",
              "concepts/rag",
              "concepts/errors"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/status",
              "api-reference/endpoint/rag-retrieve"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API Reference",
          "href": "/api-reference/introduction",
          "icon": "code"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Acessar",
      "href": "https://talk.saninternet.com/login"
    }
  },
  "api": {
    "baseUrl": "https://api-talk.saninternet.com/v1",
    "auth": {
      "method": "bearer",
      "name": "Authorization"
    }
  },
  "openapi": ["/api-reference/openapi.json"],
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "feedback": {
    "suggestEdit": true,
    "raiseIssue": true
  },
  "footer": {
    "socials": {
      "website": "https://talk.saninternet.com"
    }
  }
}
